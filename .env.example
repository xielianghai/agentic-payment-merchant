# Database (Merchant Management Platform)
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=12345678
DB_NAME=agentic_merchant_mgmt

# Merchant Management API
API_HOST=127.0.0.1
API_PORT=9100
LOG_LEVEL=INFO

# HEG Flight (external merchant system)
HEG_FLIGHT_BACKEND_URL=http://127.0.0.1:9000
HEG_FLIGHT_MCP_SERVER=/Users/ouyang/AI-coding/payment/heg_flight_mock/mcp/server.py
HEG_A2A_ENDPOINT=http://127.0.0.1:9000/a2a/heg_merchant_agent

# AP2 repo (sibling of agentic-payment-merchant under payment/)
AP2_ROOT=/Users/ouyang/AI-coding/payment/AP2

# Merchant Management registry (Adapter reads this)
MERCHANT_MGMT_API=http://127.0.0.1:9100
ADAPTER_BASE_URL=http://127.0.0.1:8200

# LLM (Shopping Agent - DeepSeek)
LLM_PROVIDER=deepseek
DEEPSEEK_API_KEY=
AGENT_MODEL=deepseek-chat
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_THINKING=disabled

# Payment stack ports
UNIFIED_AGENT_PORT=8090
UNIFIED_MERCHANT_TRIGGER_PORT=8091
UNIFIED_CP_TRIGGER_PORT=8092
UNIFIED_MPP_TRIGGER_PORT=8093
UNIFIED_X402_PSP_TRIGGER_PORT=8094
UNIFIED_TRUSTED_SURFACE_PORT=8104
UNIFIED_MONITOR_SCHEDULER_PORT=8105
UNIFIED_WEB_CLIENT_PORT=5183

# Mastercard VI (card checkout). Merchant .env overrides AP2/.env for uv-run services.
AP2_DISABLE_VI=0
AP2_VI_ENABLED=1
# AP2_VI_DEBUG=1

# Active merchant for demo
UNIFIED_MERCHANT=flight
MERCHANT_PAYMENT_PROCESSOR_URL=http://127.0.0.1:8093/initiate-payment
X402_PSP_SETTLE_URL=http://127.0.0.1:8094/settle-payment
